# PostgreSQL connection string (used by Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Supabase project URL and service role (or anon) key with storage access
# Create a bucket named exactly: fileuploader
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_KEY="your-supabase-service-role-or-key"
